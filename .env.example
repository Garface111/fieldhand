# LLM
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Database — local SQLite for dev, swap for Supabase Postgres in prod
DATABASE_URL=sqlite:///./fieldhand.db
# DATABASE_URL=postgresql://user:pass@host:5432/fieldhand

# Supabase (prod)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# HelloSign / Dropbox Sign
HELLOSIGN_API_KEY=

# Gmail OAuth
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# App
APP_ENV=development
APP_BASE_URL=http://localhost:8000
SECRET_KEY=change_this_to_a_long_random_string
